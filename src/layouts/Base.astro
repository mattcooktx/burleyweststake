---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import MetaTags, { type MetaTagsProps } from '../components/MetaTags.astro'
import { site } from '../lib/site'

interface Props {
  /** Browser tab title (without brand suffix). Defaults to brand name (which then becomes the bare home-page title). */
  title?: string
  /** Description for <meta name="description"> and the default share description. */
  description?: string
  /** Path or absolute URL for og:image / twitter:image. */
  ogImage?: string
  /** Active nav pill highlight. */
  current?: 'home' | 'stake-conference' | 'holy-week' | 'christmas' | 'collections'
  /**
   * Override OG-only fields. Pages pass these when share-preview content
   * should differ from in-page content (e.g. homepage uses static identity
   * regardless of which campaign is active).
   */
  meta?: Partial<MetaTagsProps>
}

const {
  title,
  description = site.description,
  ogImage,
  current,
  meta = {},
} = Astro.props

// Default: page title gets " — Burley Idaho West Stake" suffix. If no title
// is passed (homepage), use the brand name bare and skip the suffix.
const pageTitle = title ?? site.brand.name
const bareTitle = !title

const metaProps: MetaTagsProps = {
  pageTitle,
  bareTitle,
  description,
  ogImage,
  ...meta,
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <MetaTags {...metaProps} />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Redirect users from confirmation/recovery email links straight into /admin/.
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/'
            })
          }
        })
      }
    </script>
  </body>
</html>
