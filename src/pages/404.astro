---
import Base from '../layouts/Base.astro'
---

<Base title="Page not found" description="That page isn't here.">
  <section class="notfound">
    <div class="marker">404</div>
    <h1>That page isn't here.</h1>
    <p>
      The page you tried to reach doesn't exist on this site &mdash; maybe a link is out of date,
      or the address has a small typo. Try the homepage or browse the Collections.
    </p>
    <div class="actions">
      <a href="/">Return Home</a>
      <a href="/collections/">Browse Collections</a>
    </div>
  </section>
</Base>
