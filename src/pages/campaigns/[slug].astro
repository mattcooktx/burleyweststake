---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import Hero from '../../components/Hero.astro'
import TalksSection from '../../components/TalksSection.astro'
import PhotoTeaser from '../../components/PhotoTeaser.astro'
import ScriptureBand from '../../components/ScriptureBand.astro'
import { isPlaceholder, type Campaign } from '../../lib/campaigns'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths = (async () => {
  const campaigns = await getCollection('campaigns')
  return campaigns.map((c) => ({
    params: { slug: c.id },
    props: { campaign: c },
  }))
}) satisfies GetStaticPaths

interface Props {
  campaign: Campaign
}

const { campaign } = Astro.props as Props
const placeholder = isPlaceholder(campaign)

const navMap: Record<string, 'stake-conference' | 'holy-week' | 'christmas' | 'collections'> = {
  'stake-conference': 'stake-conference',
  'holy-week': 'holy-week',
  christmas: 'christmas',
}
const current = navMap[campaign.data.category] ?? 'collections'
const hasTalks = (campaign.data.talks?.length ?? 0) > 0
---

<Base
  current={current}
  title={campaign.data.title}
  description={campaign.data.hero_subhead}
>
  {campaign.data.hero_image ? (
    <Hero campaign={campaign} />
  ) : (
    <header class="page-header">
      <span class="eyebrow">{campaign.data.title}</span>
      <h1><em>{campaign.data.hero_headline}</em></h1>
      {campaign.data.hero_subhead && <p>{campaign.data.hero_subhead}</p>}
    </header>
  )}

  {placeholder ? (
    <section class="coming-soon-block">
      <div class="eyebrow">Coming soon</div>
      <p>
        This is a placeholder. Real content will replace it when the campaign begins.
      </p>
    </section>
  ) : (
    <>
      {hasTalks && <TalksSection campaign={campaign} withSidebar />}
      {campaign.data.photo_gallery && <PhotoTeaser campaign={campaign} />}
      {campaign.data.featured_scripture && (
        <ScriptureBand
          text={campaign.data.featured_scripture.text}
          reference={campaign.data.featured_scripture.reference}
        />
      )}
    </>
  )}
</Base>
