---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import TalksSection from '../components/TalksSection.astro'
import PhotoTeaser from '../components/PhotoTeaser.astro'
import ScriptureBand from '../components/ScriptureBand.astro'
import SocialPost from '../components/SocialPost.astro'
import Resources from '../components/Resources.astro'
import { getActiveCampaign } from '../lib/campaigns'

const campaign = await getActiveCampaign()
---

<Base
  current="home"
  title={campaign?.data.title}
  description={campaign?.data.hero_subhead}
>
  {
    campaign ? (
      <>
        <Hero campaign={campaign} />
        <TalksSection campaign={campaign} withSidebar />
        {campaign.data.photo_gallery && <PhotoTeaser campaign={campaign} />}
        {campaign.data.featured_scripture && (
          <ScriptureBand
            text={campaign.data.featured_scripture.text}
            reference={campaign.data.featured_scripture.reference}
          />
        )}
        {campaign.data.instagram_embed_code && <SocialPost campaign={campaign} />}
        <Resources />
      </>
    ) : (
      <section class="evergreen">
        <p class="eyebrow">Burley Idaho West Stake</p>
        <h1>Welcome.</h1>
        <p class="lead">
          The next campaign will appear here when it begins. In the meantime, the resources
          below are always available.
        </p>
        <Resources />
      </section>
    )
  }

  <style>
    .evergreen {
      max-width: 720px;
      margin: 0 auto;
      padding: 100px 24px 40px;
      text-align: center;
    }
    .evergreen .eyebrow {
      font-family: var(--sans);
      font-size: 11px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }
    .evergreen h1 {
      font-family: var(--serif-display);
      font-size: 56px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 20px;
    }
    .evergreen .lead {
      font-size: 18px;
      color: var(--ink-soft);
      line-height: 1.65;
      margin-bottom: 64px;
    }
  </style>
</Base>
