---
import Base from '../layouts/Base.astro'
import { getActiveCampaign } from '../lib/campaigns'

const active = await getActiveCampaign()
---

<Base current="home" title={active?.data.title}>
  <section class="placeholder-section">
    <p class="eyebrow">Coming in Epic 4</p>
    <h1>Hero, talks, photos, scripture, Instagram, and resources will render here.</h1>
    {
      active && (
        <p class="meta">
          Active campaign resolved: <strong>{active.data.title}</strong> ({active.id})
        </p>
      )
    }
  </section>

  <style>
    .placeholder-section {
      max-width: 1320px;
      margin: 0 auto;
      padding: 80px 56px;
      text-align: center;
    }
    .eyebrow {
      font-family: var(--sans);
      font-size: 11px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }
    .placeholder-section h1 {
      font-family: var(--serif-display);
      font-size: 32px;
      font-weight: 500;
      color: var(--ink);
      max-width: 720px;
      margin: 0 auto;
      line-height: 1.25;
    }
    .meta {
      font-family: var(--sans);
      font-size: 12px;
      letter-spacing: 0.08em;
      color: var(--ink-soft);
      margin-top: 24px;
    }
    @media (max-width: 900px) {
      .placeholder-section {
        padding: 48px 24px;
      }
      .placeholder-section h1 {
        font-size: 24px;
      }
    }
  </style>
</Base>
