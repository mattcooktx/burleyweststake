---
import { Image } from 'astro:assets'
import TalkBody from './body/TalkBody.astro'
import { renderTitleHtml, stripTitleMarkers } from '../lib/title'
import { formatSessionDate } from '../lib/dates'
import {
  resolveTalkPdfUrl,
  SESSION_LABELS,
  type Campaign,
  type Talk,
} from '../lib/campaigns'

interface Props {
  talk: Talk
  campaign: Campaign
}

const { talk, campaign } = Astro.props
const sessionLabel = SESSION_LABELS[talk.data.session] ?? talk.data.session

const titleHtml = renderTitleHtml(talk.data.title)
const plainTitle = stripTitleMarkers(talk.data.title)

const pdfUrl = talk.data.pdf ? resolveTalkPdfUrl(talk.id, talk.data.pdf) : undefined
const hasBody = (talk.data.body?.length ?? 0) > 0
// Empty-body talks are placeholders — show the "coming soon" block and
// suppress the PDF CTA entirely. The CTA will reappear once content is
// added (or once a PDF is uploaded).
const showPdfCta = hasBody || !!pdfUrl
---

<nav class="talk-breadcrumb" aria-label="Breadcrumb">
  <a href={`/campaigns/${campaign.id}/`}>{campaign.data.title}</a>
  <span class="sep">/</span>
  <span>{sessionLabel}</span>
  <span class="sep">/</span>
  <span>{plainTitle}</span>
</nav>

<section class="talk-hero">
  <div class="talk-eyebrow">{sessionLabel} · {formatSessionDate(new Date(talk.data.session_date))}</div>
  <h1 class="talk-title" set:html={titleHtml} />
  <div class="talk-byline">{talk.data.speaker}</div>
  {talk.data.speaker_role && <div class="talk-meta-line">{talk.data.speaker_role}</div>}
</section>

{
  talk.data.hero_image && (
    <div class="talk-hero-image">
      <figure>
        <Image
          src={talk.data.hero_image}
          alt={talk.data.hero_image_alt ?? ''}
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 1100px) 100vw, 1100px"
          loading="eager"
        />
      </figure>
    </div>
  )
}

<article class="talk-body">
  {hasBody && <TalkBody blocks={talk.data.body!} />}

  {
    !hasBody && (
      <div class="talk-coming-soon">
        <p>
          <em>
            Content from this talk will be posted soon. Check back after the speaker has
            shared their materials with the stake.
          </em>
        </p>
      </div>
    )
  }

  {
    showPdfCta && (
      <div class="pdf-cta">
        <h4>Download the Outline</h4>
        <p>
          A printable summary of the scriptures, quotations, and references shared in this talk.
        </p>
        {pdfUrl ? (
          <a href={pdfUrl} target="_blank" rel="noopener">
            Download PDF
          </a>
        ) : (
          <span class="pdf-cta-pending">PDF coming soon</span>
        )}
      </div>
    )
  }
</article>

<div class="back-link">
  <a href={`/campaigns/${campaign.id}/`}>← Back to {campaign.data.title}</a>
</div>
