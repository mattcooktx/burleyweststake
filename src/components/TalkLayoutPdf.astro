---
import {
  resolveTalkPdfUrl,
  SESSION_LABELS,
  type Campaign,
  type Talk,
} from '../lib/campaigns'

interface Props {
  talk: Talk
  campaign: Campaign
}

const { talk, campaign } = Astro.props
const sessionLabel = SESSION_LABELS[talk.data.session] ?? talk.data.session
const pdfUrl = talk.data.pdf ? resolveTalkPdfUrl(talk.id, talk.data.pdf) : undefined

// PDF-mode talks always have a pdf field (enforced by schema refine), but
// guard anyway in case schema validation slips.
const titleWords = talk.data.title.trim().split(' ')
const split = Math.max(titleWords.length - 2, 0)
const titleLead = titleWords.slice(0, split).join(' ')
const titleEm = titleWords.slice(split).join(' ')
---

<nav class="talk-breadcrumb" aria-label="Breadcrumb">
  <a href={`/campaigns/${campaign.id}/`}>{campaign.data.title}</a>
  <span class="sep">/</span>
  <span>{sessionLabel}</span>
  <span class="sep">/</span>
  <span>{talk.data.title}</span>
</nav>

<header class="pdf-talk-header">
  <div class="talk-eyebrow">{sessionLabel} · {talk.data.session_date}</div>
  <h1 class="talk-title">
    {titleLead && <>{titleLead} </>}<em>{titleEm}</em>
  </h1>
  <div class="talk-byline">{talk.data.speaker}</div>
  {talk.data.speaker_role && <div class="talk-meta-line">{talk.data.speaker_role}</div>}
</header>

{
  pdfUrl ? (
    <>
      <div class="pdf-embed">
        <iframe
          src={pdfUrl}
          title={`${talk.data.title} — PDF`}
          loading="lazy"
        />
      </div>
      <div class="pdf-mobile-fallback">
        <p>
          PDFs render best on a larger screen. Tap below to open or download the file.
        </p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a class="primary" href={pdfUrl} target="_blank" rel="noopener" style="font-family: var(--sans); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; padding: 12px 22px; background: var(--ink); color: var(--paper);">
            Open PDF
          </a>
        </div>
      </div>
      <div class="pdf-actions">
        <a class="primary" href={pdfUrl} download>
          Download PDF
        </a>
        <a href={pdfUrl} target="_blank" rel="noopener">
          Open in new tab
        </a>
      </div>
    </>
  ) : (
    <p class="empty-state">PDF for this talk is not yet available.</p>
  )
}

<div class="back-link">
  <a href={`/campaigns/${campaign.id}/`}>← Back to {campaign.data.title}</a>
</div>
