---
import SessionBlock from './SessionBlock.astro'
import CollectionsSidebar from './CollectionsSidebar.astro'
import { getTalksForCampaign, groupTalksBySession, type Campaign } from '../lib/campaigns'

interface Props {
  campaign: Campaign
  withSidebar?: boolean
}

const { campaign, withSidebar = false } = Astro.props

const talks = await getTalksForCampaign(campaign.id)
const sessions = groupTalksBySession(talks)
---

<section class="main-section" id="talks">
  <div class="main-grid" data-with-sidebar={withSidebar}>
    <div>
      <div class="talks-intro">
        <h2>Sessions &amp; <em>Speakers</em></h2>
        <p>
          Browse by session below, or visit Collections to find talks from previous stake
          conferences.
        </p>
      </div>

      {
        sessions.length === 0 ? (
          <p class="empty-state">No talks have been published for this campaign yet.</p>
        ) : (
          sessions.map((s) => (
            <SessionBlock label={s.label} date={s.date} talks={s.talks} />
          ))
        )
      }
    </div>

    {withSidebar && <CollectionsSidebar />}
  </div>
</section>

<style>
  .main-grid[data-with-sidebar='false'] {
    grid-template-columns: minmax(0, 1fr);
  }
</style>
