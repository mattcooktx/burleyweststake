---
import { Image } from 'astro:assets'
import Lightbox from './Lightbox.astro'
import type { Campaign } from '../lib/campaigns'

interface Props {
  campaign: Campaign
}

const { campaign } = Astro.props
const gallery = campaign.data.photo_gallery
if (!gallery) return null

// Default alt for bulk-uploaded photos (no per-photo metadata).
const defaultAlt = `Photo from ${campaign.data.title}`

// Merge bulk uploads (no metadata) with detailed photos (alt + featured_position).
// Detailed photos render first so featured_position assignments take priority,
// then the rest of the bulk list fills in.
type GalleryEntry = {
  file: ImageMetadata
  alt: string
  homepage_featured?: boolean
  legacyPosition?: number
}
const detailed: GalleryEntry[] = (gallery.photos ?? []).map((p) => ({
  file: p.file,
  alt: p.alt && p.alt.length > 0 ? p.alt : defaultAlt,
  homepage_featured: p.homepage_featured,
  legacyPosition: p.featured_position,
}))
const bulk: GalleryEntry[] = (gallery.bulk_photos ?? []).map((file) => ({
  file,
  alt: defaultAlt,
}))
const all: GalleryEntry[] = [...detailed, ...bulk]

if (all.length === 0) return null

// Tile picker. Three priority lanes, in order:
//   1. Photos with the new `homepage_featured: true` toggle, in list order
//   2. Photos with the legacy numeric `featured_position` 1-4, slotted into
//      that explicit position (kept for backward compat)
//   3. Fallback to the first available photo for any unfilled slot
const tiles: GalleryEntry[] = []
const taken = new Set<GalleryEntry>()
for (const photo of all) {
  if (photo.homepage_featured && tiles.length < 4) {
    tiles.push(photo)
    taken.add(photo)
  }
}
for (const photo of all) {
  if (taken.has(photo)) continue
  const pos = photo.legacyPosition
  if (pos && pos >= 1 && pos <= 4 && !tiles[pos - 1]) {
    tiles[pos - 1] = photo
    taken.add(photo)
  }
}
for (let i = 0; i < 4; i++) {
  if (tiles[i]) continue
  const fallback = all.find((p) => !taken.has(p))
  if (fallback) {
    tiles[i] = fallback
    taken.add(fallback)
  }
}
// Compact (in case all is < 4 entries).
const finalTiles = tiles.filter(Boolean) as GalleryEntry[]

const galleryTitle = gallery.title
const galleryMeta = gallery.meta
const remaining = Math.max(all.length - finalTiles.length, 0)

// Words for italic emphasis on the last word of the title (e.g. "Linger Longer").
const words = galleryTitle.trim().split(' ')
const titleLead = words.slice(0, -2).join(' ')
const titleEm = words.slice(-2).join(' ')
---

<section class="photo-teaser">
  <div class="photo-teaser-header">
    <h2>{titleLead && `${titleLead} `}<em>{titleEm}</em></h2>
    {galleryMeta && <span class="meta">{galleryMeta}</span>}
  </div>

  <div class="photo-grid">
    {
      finalTiles.map((photo, idx) => {
        const indexInAll = all.indexOf(photo)
        return (
          <button
            type="button"
            class:list={['photo-tile', idx === 0 && 'photo-tile-1']}
            data-lightbox-open={indexInAll}
            aria-label={`Open photo ${indexInAll + 1} in viewer`}
          >
            <Image
              src={photo.file}
              alt={photo.alt}
              widths={[400, 800, 1200]}
              sizes={idx === 0 ? '(max-width: 1100px) 50vw, 600px' : '(max-width: 1100px) 50vw, 300px'}
            />
            <div class="photo-tile-overlay">Click to view</div>
          </button>
        )
      })
    }

    {
      remaining > 0 && (
        <button type="button" class="photo-tile photo-tile-more" data-lightbox-open="0" aria-label="View all photos">
          <span class="num">+{remaining}</span>
          <span class="label">More Photos</span>
        </button>
      )
    }
  </div>
</section>

<Lightbox photos={all} />
