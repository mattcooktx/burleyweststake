---
import FeaturedTalkCard from './FeaturedTalkCard.astro'
import TalkCard from './TalkCard.astro'
import { talkUrl, type Talk } from '../lib/campaigns'

interface Props {
  label: string
  date: string
  talks: Talk[]
}

const { label, date, talks } = Astro.props

const featured = talks.filter((t) => t.data.featured)
const standard = talks.filter((t) => !t.data.featured)

// Italicize first word of session label (e.g., "General" Session) per the prototype.
const labelWords = label.trim().split(' ')
const firstWord = labelWords[0]
const restOfLabel = labelWords.slice(1).join(' ')
---

<div class="session">
  <div class="session-label">
    <span class="name"><em>{firstWord}</em>{restOfLabel ? ` ${restOfLabel}` : ''}</span>
    <span class="date">{date}</span>
  </div>

  {
    featured.map((talk) => (
      <FeaturedTalkCard
        title={talk.data.title}
        speaker={talk.data.speaker}
        summary={talk.data.teaser}
        href={talkUrl(talk)}
        meta={`${talk.data.speaker_role ?? talk.data.speaker} · Featured`}
      />
    ))
  }

  {
    standard.length > 0 && (
      <div class="talks-grid">
        {standard.map((talk) => (
          <TalkCard
            title={talk.data.title}
            speaker={talk.data.speaker}
            summary={talk.data.teaser}
            href={talkUrl(talk)}
          />
        ))}
      </div>
    )
  }
</div>
