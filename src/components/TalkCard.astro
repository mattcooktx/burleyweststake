---
import { renderTitleHtml } from '../lib/title'

interface Props {
  title: string
  speaker: string
  summary: string
  href?: string
}

const { title, speaker, summary, href } = Astro.props
const Tag = href ? 'a' : 'div'
const linkAttrs = href ? { href } : {}
const titleHtml = renderTitleHtml(title)
---

<Tag class="talk-card" {...linkAttrs}>
  <h4 set:html={titleHtml} />
  <div class="speaker">{speaker}</div>
  <p class="summary">{summary}</p>
  {href && <span class="arrow">View →</span>}
</Tag>
