---
interface Props {
  title: string
  speaker: string
  summary: string
  href?: string
  meta?: string
}

const { title, speaker, summary, href, meta = 'Featured' } = Astro.props
const Tag = href ? 'a' : 'div'
// Talk pages are internal — no target=_blank. (External link_url paths used to
// open in a new tab; they no longer exist on talks now that they're first-class.)
const linkAttrs = href ? { href } : {}
---

<Tag class="talk-featured" {...linkAttrs}>
  <div class="talk-meta">{meta}</div>
  <h3>{title}</h3>
  <div class="talk-speaker">{speaker}</div>
  <p class="talk-summary">{summary}</p>
  {href && <span class="talk-link">View Presentation →</span>}
</Tag>
