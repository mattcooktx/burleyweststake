---
import { renderTitleHtml } from '../lib/title'

interface Props {
  title: string
  speaker: string
  summary: string
  href?: string
}

const { title, speaker, summary, href } = Astro.props
const Tag = href ? 'a' : 'div'
const linkAttrs = href ? { href } : {}
const titleHtml = renderTitleHtml(title)
---

<Tag class="talk-featured" {...linkAttrs}>
  <div class="talk-featured-speaker">{speaker}</div>
  <h3 set:html={titleHtml} />
  <p class="talk-summary">{summary}</p>
  {href && <span class="talk-link">View Presentation →</span>}
</Tag>
