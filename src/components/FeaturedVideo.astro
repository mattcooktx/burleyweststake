---
import { extractYouTubeId, youtubePosterUrl } from '../lib/youtube'

interface Props {
  embed: string
  caption?: string
}

const { embed, caption } = Astro.props
const videoId = extractYouTubeId(embed)
if (!videoId) return null

const posterUrl = youtubePosterUrl(videoId)
// youtube-nocookie.com does not set tracking cookies until the user clicks
// play. Only loads when the user activates the placeholder, so the page's
// initial weight is just the poster image (no YouTube JS, no iframe).
const embedSrc = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`
---

<section class="featured-video" aria-label="Featured video">
  <div class="featured-video-frame">
    <button
      type="button"
      class="featured-video-poster"
      data-embed-src={embedSrc}
      aria-label="Play featured video"
    >
      <img src={posterUrl} alt="" loading="lazy" decoding="async" />
      <span class="featured-video-play" aria-hidden="true">
        <svg viewBox="0 0 68 48" width="68" height="48">
          <path
            d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
            fill="#212121"
            fill-opacity=".8"
          />
          <path d="M 45,24 27,14 27,34" fill="#fff" />
        </svg>
      </span>
    </button>
  </div>
  {caption && <p class="featured-video-caption">{caption}</p>}
</section>

<script is:inline>
  ;(() => {
    const buttons = document.querySelectorAll('.featured-video-poster')
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-embed-src')
        if (!src) return
        const iframe = document.createElement('iframe')
        iframe.setAttribute('src', src)
        iframe.setAttribute('title', 'YouTube video')
        iframe.setAttribute('frameborder', '0')
        iframe.setAttribute(
          'allow',
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share',
        )
        iframe.setAttribute('allowfullscreen', '')
        iframe.setAttribute('loading', 'eager')
        btn.replaceWith(iframe)
      })
    })
  })()
</script>

<style>
  .featured-video {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 56px 80px;
  }
  .featured-video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(44, 36, 24, 0.04),
      0 12px 32px rgba(44, 36, 24, 0.08),
      0 24px 64px rgba(44, 36, 24, 0.06);
  }
  .featured-video-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .featured-video-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    background: #000;
    cursor: pointer;
    overflow: hidden;
  }
  .featured-video-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.25s ease;
  }
  .featured-video-poster:hover img {
    opacity: 0.85;
  }
  .featured-video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    transition: transform 0.2s ease;
  }
  .featured-video-poster:hover .featured-video-play {
    transform: translate(-50%, -50%) scale(1.1);
  }
  .featured-video-play svg {
    width: 88px;
    height: auto;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.4));
  }
  .featured-video-caption {
    margin: 16px auto 0;
    max-width: 720px;
    text-align: center;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  @media (max-width: 900px) {
    .featured-video {
      padding: 0 24px 56px;
    }
    .featured-video-play svg {
      width: 64px;
    }
  }
</style>
