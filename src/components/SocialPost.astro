---
import { site } from '../lib/site'
import type { Campaign } from '../lib/campaigns'

interface Props {
  campaign: Campaign
}

const { campaign } = Astro.props
const embedCode = campaign.data.instagram_embed_code
if (!embedCode) return null
---

<section class="social">
  <div class="social-header">
    <h2>Latest from <em>Instagram</em></h2>
  </div>

  <div class="ig-embed" set:html={embedCode}></div>
  <script async src="https://www.instagram.com/embed.js"></script>

  <p class="social-cta">
    <a href={site.social.instagram} target="_blank" rel="noopener">Follow Us on Instagram →</a>
  </p>
</section>

<style>
  .ig-embed {
    max-width: 540px;
    margin: 0 auto;
    padding: 24px 0;
  }
  /* Instagram's embed iframe; keep it from blowing past our column. */
  .ig-embed :global(.instagram-media) {
    margin: 0 auto !important;
    max-width: 540px !important;
  }
</style>
